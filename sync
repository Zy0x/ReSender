# Default sync configuration for Zy0x/ReSender.
# Format: KEY=VALUE. The workflow parses this file safely; it is not sourced as shell.
#
# This file intentionally describes the default source project only. Manual
# workflow inputs and repository_dispatch payloads can override these values.

SOURCE_REPOSITORY=Web-Modder/forward-master
BRANCH_SELECTOR=main
INCLUDE_MAIN=true
MAX_BRANCHES=50
SYNC_MODE=blacklist
ALLOW_DELETE=true

# Comma-separated paths. In blacklist mode, everything is mirrored except these.
# Keep target automation/config/deploy files local to this repository.
BLACKLIST_PATHS=.git/,.github/,.lovable/,.netlify/,node_modules/,dist/,build/,coverage/,.turbo/,supabase/.temp/,.env,.env.*,**/.env,**/.env.*,sync,/*.md,supabase/,db/

# Used only when SYNC_MODE=whitelist.
WHITELIST_PATHS=

COMMIT_PREFIX=chore: sync
GIT_USER_NAME=github-actions[bot]
GIT_USER_EMAIL=github-actions[bot]@users.noreply.github.com
